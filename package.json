{
  "name": "whisper-mcp",
  "version": "0.1.0",
  "description": "MCP server for local audio transcription using Whisper",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "whisper-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "whisper",
    "transcription",
    "speech-to-text",
    "audio",
    "claude",
    "ai"
  ],
  "author": "John Wulff",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwulff/whisper-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/jwulff/whisper-mcp/issues"
  },
  "homepage": "https://github.com/jwulff/whisper-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.16"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
